generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Planos ───────────────────────────────────────────────────────────────────

model Plan {
  id         Int      @id @default(autoincrement())
  slug       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(100)
  priceCents Int      @default(0)
  aiQuota    Int?
  maxUsers   Int      @default(1)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  companies Company[]

  @@map("plans")
}

// ─── Empresa (tenant) ─────────────────────────────────────────────────────────

model Company {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(200)
  slug          String    @unique @db.VarChar(100)
  email         String    @db.VarChar(255)
  planId        Int       @default(1)
  planExpiresAt DateTime?
  aiUsedTotal   Int       @default(0)
  active        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan        Plan         @relation(fields: [planId], references: [id])
  users       User[]
  demandas    Demanda[]
  comentarios Comentario[]
  anexos      Anexo[]
  listas      Lista[]
  itensList   ItemLista[]
  tags        Tag[]

  @@map("companies")
}

// ─── Usuário ──────────────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  companyId     Int
  name          String    @db.VarChar(200)
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime?
  passwordHash  String?   @db.VarChar(255)
  role          UserRole  @default(USER)
  active        Boolean   @default(true)
  avatarUrl     String?   @db.VarChar(1000)
  lgpdConsentAt DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  accounts    Account[]
  sessions    Session[]
  demandas    Demanda[]
  comentarios Comentario[]
  anexos      Anexo[]
  listas      Lista[]

  @@index([companyId])
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

// ─── Auth.js v5 ───────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Captura (Demandas / Tarefas / Ideias) ────────────────────────────────────

enum DemandaTipo {
  DEMANDA
  TAREFA
  IDEIA
  DIARIO
}

enum DemandaStatus {
  ABERTA
  EM_ANDAMENTO
  EM_ESPERA
  CONCLUIDA
  CANCELADA
}

enum DemandaPrioridade {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

model Demanda {
  id                Int               @id @default(autoincrement())
  companyId         Int
  userId            Int
  titulo            String            @db.VarChar(500)
  descricao         String?           @db.Text
  tipo              DemandaTipo       @default(DEMANDA)
  status            DemandaStatus     @default(ABERTA)
  prioridade        DemandaPrioridade @default(MEDIA)
  prazo             DateTime?
  solicitanteNome   String?           @db.VarChar(200)
  solicitanteUserId Int?
  delegadoUserId    Int?
  delegadoNome      String?           @db.VarChar(200)
  audioUrl          String?           @db.VarChar(1000)
  aiProcessado      Boolean           @default(false)
  focoIniciadoEm       DateTime?
  focoMotivoEspera     String?   @db.VarChar(255)
  concluidoAt          DateTime?
  lembreteD1EnviadoAt  DateTime?
  lembreteD0EnviadoAt  DateTime?
  deletedAt            DateTime?
  deletedBy            Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  relatorioGerado   String?   @db.LongText
  relatorioGeradoAt DateTime?

  company     Company       @relation(fields: [companyId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  acoes       AcaoDemanda[]
  comentarios Comentario[]
  anexos      Anexo[]
  sessoesFoco SessaoFoco[]
  tags        DemandaTag[]

  @@index([companyId, userId])
  @@index([companyId, tipo])
  @@index([companyId, status])
  @@index([prazo])
  @@map("demandas")
}

model AcaoDemanda {
  id        Int       @id @default(autoincrement())
  demandaId Int
  descricao String    @db.VarChar(1000)
  feita     Boolean   @default(false)
  prazo     DateTime?
  ordem     Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("acoes_demanda")
}

// ─── Histórico de comentários / updates ──────────────────────────────────────

model Comentario {
  id        Int       @id @default(autoincrement())
  demandaId Int
  userId    Int
  companyId Int
  conteudo  String    @db.Text
  audioUrl  String?   @db.VarChar(1000)
  tipo      String    @default("NOTA") // NOTA | AUDIO | STATUS
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  deletedBy Int?

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([demandaId])
  @@index([companyId])
  @@map("comentarios")
}

// ─── Anexos ───────────────────────────────────────────────────────────────────

model Anexo {
  id        Int       @id @default(autoincrement())
  demandaId Int
  userId    Int
  companyId Int
  url       String    @db.VarChar(1000)
  nome      String    @db.VarChar(255)   // nome original do arquivo
  tipo      String    @db.VarChar(100)   // MIME type: image/jpeg, application/pdf, etc.
  tamanho   Int       @default(0)        // bytes
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  deletedBy Int?

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([demandaId])
  @@index([companyId])
  @@map("anexos")
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id        Int       @id @default(autoincrement())
  companyId Int
  nome      String    @db.VarChar(50)   // normalizado: lowercase, sem '#'
  cor       String?   @db.VarChar(20)
  deletedAt DateTime?
  deletedBy Int?
  createdAt DateTime  @default(now())

  company  Company      @relation(fields: [companyId], references: [id])
  demandas DemandaTag[]

  @@unique([companyId, nome])
  @@index([companyId])
  @@map("tags")
}

model DemandaTag {
  id        Int      @id @default(autoincrement())
  demandaId Int
  tagId     Int
  companyId Int
  createdAt DateTime @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([demandaId, tagId])
  @@index([demandaId])
  @@index([tagId])
  @@index([companyId])
  @@map("demanda_tags")
}

// ─── Listas ───────────────────────────────────────────────────────────────────

enum ListaTipo {
  COMPRAS
  VENCIMENTOS
  LEMBRETES
  GERAL
}

model Lista {
  id        Int       @id @default(autoincrement())
  companyId Int
  userId    Int
  titulo    String    @db.VarChar(300)
  descricao String?   @db.VarChar(1000)
  tipo      ListaTipo @default(GERAL)
  cor       String?   @db.VarChar(20)
  deletedAt DateTime?
  deletedBy Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company     @relation(fields: [companyId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  itens   ItemLista[]

  @@index([companyId, userId])
  @@map("listas")
}

model ItemLista {
  id                Int       @id @default(autoincrement())
  listaId           Int
  companyId         Int
  texto             String    @db.VarChar(1000)
  concluido         Boolean   @default(false)
  concluidoAt       DateTime?
  dataVencimento    DateTime?
  recorrente        Boolean   @default(false)
  lembrarAntesDias  Int?
  lembreteEnviadoAt DateTime?
  url               String?   @db.VarChar(1000)
  ordem             Int       @default(0)
  deletedAt         DateTime?
  deletedBy         Int?
  createdAt         DateTime  @default(now())

  lista   Lista   @relation(fields: [listaId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@index([listaId])
  @@index([companyId])
  @@map("itens_lista")
}

// ─── Cron ─────────────────────────────────────────────────────────────────────

// ─── Sessões de foco ──────────────────────────────────────────────────────────

model SessaoFoco {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int
  demandaId   Int
  iniciadoEm  DateTime
  encerradoEm DateTime
  duracaoMin  Int
  createdAt   DateTime @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@index([demandaId])
  @@index([companyId, userId])
  @@index([iniciadoEm])
  @@map("sessoes_foco")
}

// ─── Cron ─────────────────────────────────────────────────────────────────────

model CronExecucao {
  id          Int      @id @default(autoincrement())
  job         String   @db.VarChar(50)
  executadoEm DateTime @default(now())
  enviados    Int      @default(0)
  d0          Int      @default(0)
  d1          Int      @default(0)
  erros       Int      @default(0)
  detalhes    String?  @db.Text

  @@index([job, executadoEm])
  @@map("cron_execucoes")
}
